<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevOpsHub - Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📊 DevOpsHub Dashboard</h1>
            <p>Real-time feedback statistics</p>
        </div>

        <div class="dashboard-stats">
            <div class="stat-card large">
                <h3>Total Messages</h3>
                <p class="stat-number" id="messageCount"><%= messageCount %></p>
                <p class="stat-description">Messages received from users</p>
            </div>

            <div class="stat-card large">
                <h3>Total Visits</h3>
                <p class="stat-number" id="visitCount"><%= visitCount %></p>
                <p class="stat-description">Number of times the feedback form was accessed</p>
            </div>
        </div>

        <div class="messages-section">
            <h2>Recent Messages</h2>
            <% if (recentMessages.length > 0) { %>
                <div class="messages-list">
                    <% recentMessages.forEach((msg) => { %>
                        <div class="message-card">
                            <div class="message-header">
                                <h4><%= msg.name %></h4>
                                <span class="message-date">
                                    <%= new Date(msg.timestamp).toLocaleString('en-US') %>
                                </span>
                            </div>
                            <p class="message-email">Email: <%= msg.email %></p>
                            <p class="message-content"><%= msg.message %></p>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p>No messages yet. <a href="http://localhost:3001">Send your feedback now!</a></p>
                </div>
            <% } %>
        </div>

        <div class="footer">
            <p>🔄 Dashboard updates every 5 seconds</p>
            <p><a href="http://localhost:3001">← Back to feedback form</a></p>
        </div>
    </div>

    <script>
        // Update stats every 5 seconds
        setInterval(() => {
            fetch('/api/stats')
                .then(res => res.json())
                .then(data => {
                    document.getElementById('messageCount').textContent = data.totalMessages;
                    document.getElementById('visitCount').textContent = data.totalVisits;
                })
                .catch(err => console.error('Error:', err));
        }, 5000);

        // Refresh whole page every 30 seconds
        setTimeout(() => location.reload(), 30000);
    </script>
</body>
</html>
